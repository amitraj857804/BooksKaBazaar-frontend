# API Configuration
VITE_API_URL=http://localhost:8080/api

# Mock API Toggle (for testing without backend)
# Set to 'true' to use mock API (default)
# Set to 'false' to use real backend
VITE_USE_MOCK_API=true

# SuperAdmin Credentials (for testing only)
# Use these credentials in the SuperAdmin login page


# Backend Configuration
VITE_JWT_STORAGE_KEY=superAdminToken
VITE_USER_STORAGE_KEY=superAdminUser
