# API Configuration
VITE_API_URL=http://localhost:8080/api

# Mock API Toggle (for testing without backend)
# Set to 'true' to use mock API (default)
# Set to 'false' to use real backend
VITE_USE_MOCK_API=true

# SuperAdmin Credentials (for testing only)
# Use these credentials in the SuperAdmin login page


# Backend Configuration
VITE_JWT_STORAGE_KEY=superAdminToken
VITE_USER_STORAGE_KEY=superAdminUser

# Coming Soon Landing Page Toggle (set to 'true' to display landing page, 'false' for regular app)
VITE_COMING_SOON=true

# Coming Soon Launch Target Date (Format: YYYY-MM-DDTHH:MM:SS)
VITE_LAUNCH_DATE=2026-07-01T00:00:00

# EmailJS Service Credentials (Third-party Email Service)
VITE_EMAILJS_SERVICE_ID=service_3ofqjh6
VITE_EMAILJS_TEMPLATE_ID=template_hin018m
